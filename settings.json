{
  "permissions": {
    "allow": [
      "PowerShell",
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "WebFetch"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"$json = $input | ConvertFrom-Json; $out = @{ hookSpecificOutput = @{ hookEventName = 'PreToolUse'; permissionDecision = 'deny'; permissionDecisionReason = '請改用子代理（Agent, model: haiku）執行檔案搜尋，不得在主對話直接呼叫 Glob 或 Grep' } } | ConvertTo-Json -Depth 5 -Compress; Write-Output $out\"",
            "shell": "powershell"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -Command \"$json = $input | ConvertFrom-Json; $out = @{ hookSpecificOutput = @{ hookEventName = 'PreToolUse'; permissionDecision = 'deny'; permissionDecisionReason = '請改用子代理（Agent, model: haiku）執行網頁抓取，不得在主對話直接呼叫 WebFetch' } } | ConvertTo-Json -Depth 5 -Compress; Write-Output $out\"",
            "shell": "powershell"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\yuchi\\.claude\\session-start-inject-state.ps1\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\yuchi\\.claude\\session-start-menu.ps1\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\yuchi\\.claude\\review-reminder.ps1\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\yuchi\\.claude\\cache-check.ps1\"",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\yuchi\\.claude\\clear-reminder.ps1\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File \"C:\\Users\\yuchi\\.claude\\pre-compact-memory-save.ps1\"",
            "timeout": 40,
            "async": true
          }
        ]
      }
    ]
  },
  "enabledPlugins": {},
  "autoCompactWindow": 170000,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "verbose": false,
  "autoCompactEnabled": false
}
